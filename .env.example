# API Endpoints Configuration
# Copy this file to .env.local and adjust for your local development environment

# URL of the backend API
VITE_API_BASE_URL=http://129.241.150.141:8000
# VITE_API_BASE_URL=http://localhost:8000

# VM / prod setup (recommended):
# Serve the frontend over HTTPS and use a reverse proxy to forward /api -> http://localhost:8000
# This avoids managing HTTPS certificates for the backend.
# VITE_API_BASE_URL=/api

# Optional: If you use VITE_API_BASE_URL=/api in local development, Vite can proxy /api to a backend.
# VITE_API_PROXY_TARGET=http://129.241.150.141:8000

# Helsedirektoratet API Key for external content
VITE_HELSEDIR_API_KEY=your-api-key-here
VITE_HELSEDIR_API_URL=https://api.helsedirektoratet.no